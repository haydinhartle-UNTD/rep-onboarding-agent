# Anthropic — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Blooio — get from your Blooio dashboard
BLOOIO_API_KEY=...

# Your cell phone in E.164 format (e.g. +16025551234)
NOTIFY_PHONE_NUMBER=+1xxxxxxxxxx

# The installer's Typeform URL
INSTALLER_TYPEFORM_URL=https://form.typeform.com/to/trmZGOwt

# Long random string — must match what Zapier sends in X-Webhook-Secret header
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
ZAPIER_WEBHOOK_SECRET=...

# Safety cap on Computer Use agent loop iterations (prevents runaway cost)
MAX_AGENT_ITERATIONS=40
